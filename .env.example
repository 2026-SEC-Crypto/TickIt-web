# Base URL for TickIt API (no trailing slash)
API_URL=http://localhost:9292/api/v1

# Session cookie signing secret (at least 64 characters in production)
SESSION_KEY=dev-tickit-secure-key-minimum-64-characters-required-for-production-use-now

# NaCl encryption key for session payload (Base64)
# Generate with: ruby -e "require 'rbnacl'; puts Base64.strict_encode64(RbNaCl::Random.random_bytes(32))"
MSG_KEY=

# Google OAuth / OpenID Connect
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Local dev default callback URL. Use your deployed HTTPS URL in production.
GOOGLE_REDIRECT_URI=http://localhost:9292/auth/google/callback
GOOGLE_OAUTH_SCOPE=openid email profile
