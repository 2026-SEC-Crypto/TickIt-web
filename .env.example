# Development environment variables
# Copy this file to .env and customize for your local development

# Database configuration
DATABASE_URL=sqlite://db/local/development.db

# Encryption and security keys
ENCRYPTION_KEY=dev-key-must-be-at-least-32-bytes-long!!
SESSION_KEY=dev-session-key-must-be-at-least-64-characters-required-for-production-use-now
MSG_KEY=dev-message-key

# Environment
RACK_ENV=development

# API URL (web app uses this to call the API)
# Local development points to localhost
# Production should point to deployed API
API_URL=http://localhost:9292/api/v1

# Optional: Redis for session storage (leave empty for in-memory sessions in dev)
REDIS_URL=
